{
  "$comment": "JSON Schema validation is necessary but insufficient; artifact bytes must be validated with load_artifact_from_json_bytes and Pydantic model_validate_json. Pydantic requires left_provenance_id and right_provenance_id to be distinct.",
  "$defs": {
    "ConflictStatus": {
      "enum": [
        "open",
        "adjudicated",
        "insufficient"
      ],
      "title": "ConflictStatus",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "claim_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "title": "Claim Id",
      "type": "string"
    },
    "conflict_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "title": "Conflict Id",
      "type": "string"
    },
    "conflict_type": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "title": "Conflict Type",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "left_provenance_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "title": "Left Provenance Id",
      "type": "string"
    },
    "producer_version": {
      "minLength": 1,
      "pattern": "^\\S(?:[\\s\\S]*\\S)?$",
      "title": "Producer Version",
      "type": "string"
    },
    "rationale": {
      "minLength": 1,
      "pattern": "^\\S(?:[\\s\\S]*\\S)?$",
      "title": "Rationale",
      "type": "string"
    },
    "right_provenance_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "title": "Right Provenance Id",
      "type": "string"
    },
    "run_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "conflict_record.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ConflictStatus"
    }
  },
  "required": [
    "producer_version",
    "run_id",
    "created_at",
    "schema_version",
    "conflict_id",
    "claim_id",
    "left_provenance_id",
    "right_provenance_id",
    "conflict_type",
    "status",
    "rationale"
  ],
  "title": "ConflictRecord",
  "type": "object"
}
